{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gr86p.telemetry.schema.v0.1",
  "title": "GR86P Telemetry Snapshot",
  "type": "object",
  "additionalProperties": false,
  "required": ["trip", "telemetry_now"],
  "properties": {
    "trip": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trip_id", "state", "elapsed_sec"],
      "properties": {
        "trip_id": { "type": "string", "minLength": 1 },
        "state": { "type": "string", "enum": ["IDLE", "DRIVING", "ENDED"] },
        "elapsed_sec": { "type": "number", "minimum": 0 }
      }
    },

    "telemetry_now": {
      "type": "object",
      "additionalProperties": false,
      "required": ["engine", "speed", "controls", "steering", "transmission", "temperatures", "fuel", "tpms"],
      "properties": {
        "engine": {
          "type": "object",
          "additionalProperties": false,
          "required": ["rpm", "neutral_gear"],
          "properties": {
            "rpm": { "type": "integer", "minimum": 0, "maximum": 10000 },
            "neutral_gear": { "type": "boolean" }
          }
        },

        "speed": {
          "type": "object",
          "additionalProperties": false,
          "required": ["vehicle_mph"],
          "properties": {
            "vehicle_mph": { "type": "number", "minimum": 0, "maximum": 250 },

            "wheel_speeds_mph": {
              "type": ["object", "null"],
              "additionalProperties": false,
              "required": ["front_left", "front_right", "rear_left", "rear_right"],
              "properties": {
                "front_left": { "type": "number", "minimum": 0, "maximum": 250 },
                "front_right": { "type": "number", "minimum": 0, "maximum": 250 },
                "rear_left": { "type": "number", "minimum": 0, "maximum": 250 },
                "rear_right": { "type": "number", "minimum": 0, "maximum": 250 }
              }
            }
          }
        },

        "controls": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "accelerator_position_pct",
            "brake_light_switch",
            "brake_pressure_raw",
            "brake_pressure_est",
            "brake_position_pct",
            "clutch_position_pct"
          ],
          "properties": {
            "accelerator_position_pct": { "type": "number", "minimum": 0, "maximum": 100 },

            "brake_light_switch": { "type": "boolean" },

            "brake_pressure_raw": { "type": "integer", "minimum": 0, "maximum": 65535 },

            "brake_pressure_est": {
              "type": "object",
              "additionalProperties": false,
              "required": ["units", "value"],
              "properties": {
                "units": { "type": "string", "enum": ["unknown", "arb", "kpa", "psi"] },
                "value": { "type": "number", "minimum": 0 }
              }
            },

            "brake_position_pct": { "type": "number", "minimum": 0, "maximum": 100 },

            "clutch_position_pct": { "type": "number", "minimum": 0, "maximum": 100 }
          }
        },

        "steering": {
          "type": "object",
          "additionalProperties": false,
          "required": ["angle_deg"],
          "properties": {
            "angle_deg": { "type": "number", "minimum": -1000, "maximum": 1000 }
          }
        },

        "transmission": {
          "type": "object",
          "additionalProperties": false,
          "required": ["gear", "reverse_gear"],
          "properties": {
            "gear": { "type": "integer", "minimum": 0, "maximum": 8 },
            "reverse_gear": { "type": "boolean" }
          }
        },

        "temperatures": {
          "type": "object",
          "additionalProperties": false,
          "required": ["oil_temp_f", "coolant_temp_f", "intake_air_temp_f"],
          "properties": {
            "oil_temp_f": { "type": "number", "minimum": -40, "maximum": 400 },
            "coolant_temp_f": { "type": "number", "minimum": -40, "maximum": 400 },
            "intake_air_temp_f": { "type": "number", "minimum": -40, "maximum": 250 }
          }
        },

        "fuel": {
          "type": "object",
          "additionalProperties": false,
          "required": ["fuel_level_pct"],
          "properties": {
            "fuel_level_pct": { "type": "number", "minimum": 0, "maximum": 100 }
          }
        },

        "tpms": {
          "type": "object",
          "additionalProperties": false,
          "required": ["warning", "tire_pressure_psi"],
          "properties": {
            "warning": { "type": "boolean" },

            "tire_pressure_psi": {
              "type": ["object", "null"],
              "additionalProperties": false,
              "required": ["front_left", "front_right", "rear_left", "rear_right"],
              "properties": {
                "front_left": { "type": ["number", "null"], "minimum": 0, "maximum": 80 },
                "front_right": { "type": ["number", "null"], "minimum": 0, "maximum": 80 },
                "rear_left": { "type": ["number", "null"], "minimum": 0, "maximum": 80 },
                "rear_right": { "type": ["number", "null"], "minimum": 0, "maximum": 80 }
              }
            },

            "tire_pressure_kpa": {
              "type": ["object", "null"],
              "additionalProperties": false,
              "required": ["front_left", "front_right", "rear_left", "rear_right"],
              "properties": {
                "front_left": { "type": ["number", "null"], "minimum": 0, "maximum": 700 },
                "front_right": { "type": ["number", "null"], "minimum": 0, "maximum": 700 },
                "rear_left": { "type": ["number", "null"], "minimum": 0, "maximum": 700 },
                "rear_right": { "type": ["number", "null"], "minimum": 0, "maximum": 700 }
              }
            }
          }
        }
      }
    }
  }
}